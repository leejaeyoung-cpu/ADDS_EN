# ADDS 시스템 환경 설정

# OpenAI API 키 (의료 문서 분석용)
# 사용법: 아래 YOUR_API_KEY_HERE를 실제 OpenAI API 키로 교체하세요
# OPENAI_API_KEY=sk-proj-...

# 또는 시스템 환경 변수로 설정:
# Windows: setx OPENAI_API_KEY "your-api-key-here"
# Linux/Mac: export OPENAI_API_KEY="your-api-key-here"

# 의료 문서 저장 경로
MEDICAL_DOCUMENTS_DIR=data/medical_documents

# AI 분석 설정
AI_ANALYSIS_ENABLED=true
AI_MODEL=gpt-4o  # GPT-4 with vision
AI_MAX_TOKENS=1500
AI_TEMPERATURE=0.3

# 데이터베이스 설정
CLINICAL_DB_PATH=data/clinical/clinical_data.db
ANALYSIS_DB_PATH=data/analysis_results.db

# 파일 업로드 제한
MAX_FILE_SIZE_MB=50
ALLOWED_IMAGE_EXTENSIONS=.jpg,.jpeg,.png,.tif,.tiff
ALLOWED_DOCUMENT_EXTENSIONS=.pdf,.txt,.docx
