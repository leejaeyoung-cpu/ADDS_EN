# ADDS Environment Configuration
# Copy this file to .env and update with your actual values

# OpenAI Configuration (for AI Medical Research)
OPENAI_API_KEY=your_api_key_here
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=2000
OPENAI_TEMPERATURE=0.7

# Enable/Disable AI Research
ENABLE_AI_RESEARCH=true

# Database Configuration
ADDS_DB_PASSWORD=your_password_here
ADDS_DB_HOST=localhost
ADDS_DB_PORT=5432
ADDS_DB_NAME=adds_db
ADDS_DB_USER=adds_user

# CUDA Configuration (toggle between CPU and GPU)
# Set to 'cuda' to use GPU, 'cpu' to use CPU
# RTX 5070 sm_120 호환성 문제로 인해 현재는 CPU 권장
ADDS_DEVICE=cpu

# Cellpose GPU Override
# Set to 'true' to force GPU usage, 'false' for CPU
ADDS_CELLPOSE_GPU=false

# MLflow Configuration
MLFLOW_TRACKING_URI=file:./mlruns
MLFLOW_EXPERIMENT_NAME=ADDS_experiments

# AI Analysis (Optional)
# OpenAI API key for AI-powered analysis insights
# Get your key at: https://platform.openai.com/api-keys
# Note: AI analysis works without this key (fallback to statistical analysis only)
OPENAI_API_KEY=sk-your_key_here

# Optional: Other external services
# WANDB_API_KEY=your_key_here
