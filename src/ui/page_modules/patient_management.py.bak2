                            st.warning("\u26a0\ufe0f \uc138\ud3ec AI \ubd84\uc11d\uc744 \uba3c\uc800 \uc2e4\ud589\ud558\uc138\uc694 (\u25b6 AI \ubd84\uc11d \uc2dc\uc791 \ubc84\ud2bc).")
                            fb_cols = st.columns(min(5, len(cell_imgs_raw)))
                            from PIL import Image as _PIL2
                            for i, col in enumerate(fb_cols):
                                with col:
