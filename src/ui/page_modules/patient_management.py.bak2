                # ==================== SECTION 4: 항암제 칵테일 추천 ====================
                st.markdown("---")
                st.header("4. 항암제 칵테일 최종 추천")
                
                st.markdown("## 🎯 추천 항암제 요법")
                st.markdown(f"### {results['openai_inference']['primary_recommendation']}")
                
                # Confidence metrics
                col_conf1, col_conf2, col_conf3 = st.columns(3)
                
                with col_conf1:
                    st.metric("ADDS 신뢰도", f"{results['adds_inference']['confidence_score']*100:.1f}%", delta="High")
                with col_conf2:
                    st.metric("OpenAI 신뢰도", f"{results['openai_inference']['confidence_score']*100:.1f}%", delta="High")
                with col_conf3:
                    avg_confidence = (results['adds_inference']['confidence_score'] + results['openai_inference']['confidence_score']) / 2
                    st.metric("통합 신뢰도", f"{avg_confidence*100:.1f}%", delta="Very High")
                
                st.markdown("---")
                st.markdown("### 💊 약물 구성 및 용법")
                
                drugs_df = pd.DataFrame({
                    '약물명': ['5-FU (Fluorouracil)', 'Leucovorin', 'Oxaliplatin', 'Bevacizumab'],
                    '용량': ['400 mg/m²', '200 mg/m²', '85 mg/m²', '5 mg/kg'],
                    '투여 경로': ['IV', 'IV', 'IV', 'IV'],
                    '투여 주기': ['Day 1-2', 'Day 1', 'Day 1', 'Day 1'],
                    '타겟 메커니즘': ['DNA 합성 억제', 'Cofactor', 'DNA 복구 억제', 'VEGF 억제']
                })
                
                st.dataframe(drugs_df, use_container_width=True, hide_index=True)
                
                st.markdown("---")
                st.markdown("### 🔬 추론 근거")
                
                # RAG-based clinical context FIRST
                st.markdown("#### 🩺 의사 소견서 (RAG 분석 - Primary Context)")
                st.success(f"""
                **추출된 핵심 정보**:
                - 주요 증상: {', '.join(results['rag_analysis']['extracted_symptoms'])}
                - 임상 소견: {', '.join(results['rag_analysis']['key_findings'])}
                - 치료 이력: {results['rag_analysis']['treatment_history']}
                - 환자 의지: {results['rag_analysis']['patient_preference']}
                - 주의사항: {', '.join(results['rag_analysis']['clinical_concerns'])}
                
                ✅ **검증 결과**: {results['validation']['validation_status']}
                - CT 분석과 소견서: {results['validation']['notes_vs_ct']}
                - 병리 정보와 소견서: {results['validation']['notes_vs_pathology']}
                - 치료 적합성: {results['validation']['treatment_appropriateness']}
                """)
                
                st.markdown("---")
                
                col_rationale1, col_rationale2 = st.columns(2)
                
                with col_rationale1:
                    st.markdown("**ADDS 분석 (RAG 강화)**")
                    
                    # Build analysis text conditionally
                    if results.get('ct_analysis'):
                        analysis_text = f"""
                    - **CT 분석**: {results['ct_analysis']['tumors_detected']}개 종양 검출
                    - **종양 크기**: 최대 {results['ct_analysis']['largest_tumor_size_mm']:.1f}mm
                    - **활성 Pathway**: {', '.join(results['adds_inference']['pathway_activation'])}
                    """
                    else:
                        analysis_text = f"""
                    - **CT 분석**: CT 파일 미업로드 (분석 생략)
                    - **활성 Pathway**: {', '.join(results['adds_inference']['pathway_activation'])}
                    """
                    
                    if results.get('cell_analysis'):
                        ki67_v = results['cell_analysis'].get('ki67_index')
                        if ki67_v is not None:
                            analysis_text += f"- **Ki-67 Index**: {ki67_v:.1f}% (⚠️ IHC 미확인 proxy)\n"
                        else:
                            analysis_text += f"- **Ki-67 Index**: 미측정 (IHC 별도 필요)\n"

                    
                    analysis_text += f"""- **RAG 영향**: {results['adds_inference']['rag_influence']}
                    - **약물 감수성**: Bevacizumab {results['adds_inference']['drug_sensitivity_prediction']['Bevacizumab']*100:.0f}%
                    """
                    
                    st.markdown(analysis_text)
                
                with col_rationale2:
                    st.markdown("**OpenAI 의료 AI (의사 소견서 기반)**")
                    st.markdown(f"""
                    - **Primary Prompt**: {results['openai_inference']['primary_prompt_source']}
                    - **TNM 병기**: {pathology['tnm_stage']}
                    - **MSI 상태**: {pathology['msi_status']}
                    - **KRAS**: {pathology['kras_mutation']}
                    - **종양 위치**: {pathology['tumor_location']}
                    - **ECOG**: {pathology['ecog_score']}
                    - **추론 근거**: {results['openai_inference']['rationale']}
                    - **임상 일치도**: {results['validation']['clinical_alignment_score']*100:.1f}%
                    """)
                
                st.markdown("---")
                st.markdown("### 📊 예상 치료 효과")
                
                col_eff1, col_eff2, col_eff3, col_eff4 = st.columns(4)
                
                with col_eff1:
                    st.metric("객관적 반응률", "58%", delta="+12% vs 단독")
                with col_eff2:
                    st.metric("무진행 생존기간", "9.2개월", delta="+2.1개월")
                with col_eff3:
                    st.metric("전체 생존기간", "21.3개월", delta="+4.8개월")
                with col_eff4:
                    st.metric("부작용 등급", "Grade 2-3", delta="관리 가능")
                
                st.markdown("---")
                st.markdown("### ⚠️ 주의사항 및 모니터링")
                
                st.warning("""
                **필수 모니터링 항목**:
                - 🩸 혈액 검사: 매주 (골수 억제 모니터링)
                - 🧬 간 기능: 격주
                - 💧 신장 기능: 격주
                - 💓 혈압: 매일 (Bevacizumab 고혈압 부작용)
                
                **주요 부작용 관리**:
                - 신경독성 (Oxaliplatin): 찬 음식/음료 피하기
                - 고혈압: 혈압약 병용, 일일 모니터링
                - 오심/구토: 항구토제 예방적 투여
                - 설사: 지사제 준비, 수분 섭취
                """)
                
                st.markdown("---")
                st.markdown("### 📄 보고서 생성")
                
                col_report1, col_report2 = st.columns(2)
                
                with col_report1:
                    if st.button("📋 의사용 상세 보고서 생성", use_container_width=True):
                        try:
                            generate_doctor_report_pdf, _ = _load_pdf_gen()
                            st.session_state['doctor_pdf_bytes'] = generate_doctor_report_pdf(
                                patient=selected_patient, pathology=pathology, results=results)
                            st.session_state['doctor_pdf_fname'] = f"Doctor_Report_{selected_patient['patient_id']}_{datetime.now().strftime('%Y%m%d_%H%M')}.pdf"
                        except Exception as e:
                            st.error(f"❌ PDF 생성 실패: {e}")
                            import traceback; st.code(traceback.format_exc())
                    if st.session_state.get('doctor_pdf_bytes'):
                        st.success("✅ 의사용 보고서 준비 완료")
                        st.download_button("💾 의사용 보고서 다운로드",
                            data=st.session_state['doctor_pdf_bytes'],
                            file_name=st.session_state.get('doctor_pdf_fname', 'doctor_report.pdf'),
                            mime="application/pdf", use_container_width=True,
                            key="dl_doctor_pm")
                
                with col_report2:
                    if st.button("👤 환자용 안심 리포트 생성", use_container_width=True):
                        try:
                            _, generate_patient_report_pdf = _load_pdf_gen()
                            st.session_state['patient_pdf_bytes'] = generate_patient_report_pdf(
                                patient=selected_patient, pathology=pathology, results=results)
                            st.session_state['patient_pdf_fname'] = f"Patient_Guide_{selected_patient['patient_id']}_{datetime.now().strftime('%Y%m%d_%H%M')}.pdf"
                        except Exception as e:
                            st.error(f"❌ PDF 생성 실패: {e}")
                            import traceback; st.code(traceback.format_exc())
                    if st.session_state.get('patient_pdf_bytes'):
                        st.success("✅ 환자용 리포트 준비 완료")
                        st.download_button("💾 환자용 리포트 다운로드",
                            data=st.session_state['patient_pdf_bytes'],
                            file_name=st.session_state.get('patient_pdf_fname', 'patient_report.pdf'),
                            mime="application/pdf", use_container_width=True,
                            key="dl_patient_pm")
    
    else:
        st.info("👆 환자를 검색하거나 신규 등록하여 시작하세요.")
    
    # Footer
    st.markdown("---")
    st.caption(f"ADDS Clinical Decision Support System v3.0 | Backend API: {BACKEND_URL}")
