                                        st.image(_PIL2.open(cell_imgs_raw[i]),
                                                 caption=f"Sample {i+1} (\uc6d0\ubcf8)",
                                                 use_container_width=True)
                                    except Exception:
                                        st.warning(f"Sample {i+1} \ud45c\uc2dc \uc2e4\ud328")
                        else:
                            st.info("\uc138\ud3ec \uc774\ubbf8\uc9c0\ub97c \uc5c5\ub85c\ub4dc\ud558\uba74 \uc5b4\ub178\ud14c\uc774\uc158 \uacb0\uacfc\uac00 \ud45c\uc2dc\ub429\ub2c8\ub2e4.")



                
                # NEW: 3D Interactive Visualization with PyVista
                if pathology.get('ct_files_count', 0) > 0 and analyzed_images and len(analyzed_images) > 0:
                    st.markdown("---")
                    st.markdown("##### 🎭 3D 인터랙티브 뷰어")
                    st.caption("회전, 줌, 이동 가능한 3D CT 및 종양 모델")
                    
                    # Create tabs for 2D and 3D views
                    tab_2d, tab_3d = st.tabs(["📸 2D 슬라이스", "🎭 3D 모델"])
                    
                    with tab_2d:
                        st.info("위 2D 슬라이스 이미지를 참조하세요")
                    
                    with tab_3d:
                        # Check if PyVista HTML exists or needs to be generated
                        patient_id = selected_patient['patient_id']
                        output_base = Path(f"outputs/{patient_id}")
                        pyvista_html_path = output_base / "visualization" / "3d_viewer.html"
                        
                        if pyvista_html_path.exists():
