                                    백엔드 API가 이 파일들을 생성했는지 확인하세요.
                                    """)
                                    
                                    # Show fallback message
                                    st.warning("⚠️ 3D 뷰어는 NIfTI 파일이 준비되면 자동 생성됩니다.")

                
                st.markdown("---")
                
                col_res1, col_res2, col_res3, col_res4 = st.columns(4)
                
                with col_res1:
                    ct_res = results.get('ct_analysis')
                    if ct_res:
