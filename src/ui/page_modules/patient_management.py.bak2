                        st.caption("CT 파일 미업로드")

                with col_res2:
                    # Only show cell analysis if cell images were uploaded
                    if pathology.get('cell_images_count', 0) > 0:
                        _cell = results.get('cell_analysis') or {}
                        _total = _cell.get('total_cells')
                        st.metric("암세포 수",
